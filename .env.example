# Conexão com PostgreSQL (obrigatório)
DATABASE_URL=postgresql://usuario:senha@localhost:5432/enghub

# Chave secreta para sessões (obrigatório em produção)
SESSION_SECRET=minha-chave-secreta-aqui

# Ambiente (development ou production)
NODE_ENV=development

# Porta do servidor (padrão: 3001)
PORT=3001

# Diretório para uploads (padrão: ./uploads)
# UPLOAD_DIR=/caminho/para/uploads

# CORS origin (padrão: *)
# CORS_ORIGIN=https://meusite.com
